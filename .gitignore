# cyberpunk-2077 workspace — .gitignore
#
# This repo tracks: README.md, .gitignore, 00-CONTROL/, 09-DOCS/, 99-MANIFESTS/
# Everything else is ignored — repos are catalogued in 99-MANIFESTS/git-repositories.txt
# Artifacts are checksummed in 99-MANIFESTS/artifact-sha256.txt

# ── DEVELOPMENT REPOS ────────────────────────────────────────────────────────
# All nested git repos and source trees live here.
# Their remotes/branches are recorded in 99-MANIFESTS/git-repositories.txt.
01-DEVELOPMENT/

# ── PRODUCTION ARTIFACTS ─────────────────────────────────────────────────────
# Release ZIPs are SHA-256'd in 99-MANIFESTS/production-artifact-sha256.txt.
02-PRODUCTION/

# ── BUILD WORKSPACE ───────────────────────────────────────────────────────────
03-BUILD/

# ── ANDROID DEVICE FILES ──────────────────────────────────────────────────────
04-ANDROID/

# ── LINUX HOST SCRIPTS ────────────────────────────────────────────────────────
# Contains broken symlinks from home-dir restructure; scripts live in ~/scripts/
05-LINUX/

# ── UI THEMES / ANIMATIONS / WALLPAPERS ──────────────────────────────────────
# Nested git repos (Cyberpunk-Neon, cybrland, cybrpapers, etc.)
# and large binary assets (PNG, WebP, OGG, ZIP).
06-UI-THEMES-ANIMATIONS/

# ── KERNEL SOURCES & BOOT IMAGES ─────────────────────────────────────────────
07-KERNEL-PACKAGE-MODULES/

# ── SECURITY / NETHUNTER RESEARCH ────────────────────────────────────────────
08-HACKING-RESEARCH/

# ── QUARANTINE ────────────────────────────────────────────────────────────────
10-QUARANTINE-invalid-downloads/

# ── BINARY FILE TYPES (catch-all if anything leaks through) ──────────────────
*.zip
*.img
*.apk
*.tar.xz
*.tar.gz
*.tar.bz2
*.ogg
*.png
*.jpg
*.jpeg
*.webp
*.svg

# ── TOOLING ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
.vscode/
*.swp
*.swo
