# cyberpunk-2077 workspace .gitignore
#
# Policy: keep the workspace source tree visible to git so GitHub agents can
# inspect and edit the project. Ignore only local tool state, nested repository
# internals, generated caches, and files that cannot be pushed through normal
# GitHub git hosting without Git LFS.

# Local git internals from nested reference clones. The parent repo should not
# absorb object databases, packfiles, reflogs, or hooks from embedded repos.
**/.git/

# Local agent/editor/tool state.
.claude/
.codex/
.agents/
.vscode/
.idea/
*.swp
*.swo
*~

# Python and local environments.
.venv/
venv/
env/
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# OS noise.
.DS_Store
Thumbs.db

# Local Android device/download dumps. These are not source workspace inputs
# and include third-party APKs/images/tarballs that exceed GitHub's 100 MB
# normal git object limit.
04-ANDROID/device/sdcard-Download/
04-ANDROID/device/**/*.apk
04-ANDROID/device/**/*.img
04-ANDROID/device/**/*.tar.xz
04-ANDROID/device/**/*.tar.gz
04-ANDROID/device/**/*.tar.bz2
# ARM64 root filesystem archives.
04-ANDROID/arm64/

# Device-specific kernel/boot images — never commit binary blobs to this repo.
07-KERNEL-PACKAGE-MODULES/kernel/boot.img
07-KERNEL-PACKAGE-MODULES/kernel/magisk_patched*.img

# Known oversized artifacts (>50 MB) that GitHub rejects or warns on.
# Keep manifests and checksums tracked instead; use GitHub Releases for ZIPs.
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro/bootanimation/og4k/bootanimation.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro/release/CP2077-OP7Pro-v3.1.0-variant-Original-4K.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-Universal/release/CP2077-Universal-v1.0.0.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro/release/CP2077-OP7Pro-v2.0.0-beta-megapack.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro-Ultimate/release/CP2077-OP7Pro-v2.0.0-ultimate-all-in-one.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro/release/CP2077-OP7Pro-v3.1.0.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro-Ultimate/bootanimation/og1080p/bootanimation.zip
02-PRODUCTION/magisk-modules/surfaceocean-los21/boot.img
# Universal per-variant release ZIPs (58–96 MB each).
01-DEVELOPMENT/repos/cyberpunk/CP2077-Universal/release/per-variant/
# Universal source download cache (60–70 MB each).
01-DEVELOPMENT/repos/cyberpunk/CP2077-Universal/.downloads/
# OP7Pro-Ultimate pre-built bootanimation ZIPs (59–69 MB each).
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro-Ultimate/bootanimation/glitch/bootanimation.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro-Ultimate/bootanimation/flatline/bootanimation.zip
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro-Ultimate/bootanimation/reboot/bootanimation.zip
# Generated artifact inventory TSV — too large (53 MB) and always stale.
99-MANIFESTS/artifact-inventory.tsv

# Primary module source — nested git repo, part of this workspace.
# No separate GitHub remote; source is tracked within lchtangen/cyberpunk-2077.
# Re-clone locally if accidentally deleted: the directory lives here as a standalone git repo.
01-DEVELOPMENT/repos/cyberpunk/CP2077-OP7Pro/


# Third-party cloned reference repos — too large for GitHub without LFS.
# These are kernel sources, ROM device trees, icon theme collections, and
# upstream reference repos (Magisk, FFmpeg, media tools, CI/CD tools, Wayland,
# UI frameworks) that total 10+ GB. They are catalogued in
# 99-MANIFESTS/git-repositories.txt. Re-clone locally with:
# bash 99-MANIFESTS/generate-manifests.sh
01-DEVELOPMENT/repos/android-roms/
01-DEVELOPMENT/repos/android-frameworks/
01-DEVELOPMENT/repos/arch-linux/
01-DEVELOPMENT/repos/ci-cd-tools/
01-DEVELOPMENT/repos/kali-nethunter/
01-DEVELOPMENT/repos/magisk-ecosystem/
01-DEVELOPMENT/repos/media-tools/
01-DEVELOPMENT/repos/oneplus-7-pro/
05-LINUX/ui-tools/
05-LINUX/wayland-compositors/
06-UI-THEMES-ANIMATIONS/repos/
07-KERNEL-PACKAGE-MODULES/kernel/neptune-kernel-sm8150/
07-KERNEL-PACKAGE-MODULES/kernel/blu-spark-kernel-op7/
07-KERNEL-PACKAGE-MODULES/kernel/kali-nethunter-kernel-builder
07-KERNEL-PACKAGE-MODULES/kernel/kernelsu-lineageos-guacamole/
07-KERNEL-PACKAGE-MODULES/repos/op5/
07-KERNEL-PACKAGE-MODULES/repos/op7/
07-KERNEL-PACKAGE-MODULES/repos/op8/
08-HACKING-RESEARCH/nethunter/hightech-kali-nethunter-suite

# Generated dependency/build caches commonly present in cloned reference repos.
node_modules/
dist/
build/
out/
target/
.gradle/
.cxx/
cmake-build-*/
