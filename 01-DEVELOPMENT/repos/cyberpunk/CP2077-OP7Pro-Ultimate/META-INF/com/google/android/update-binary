#!/sbin/sh
# Magisk Module Installer — CP2077 Full Edition v3.0.0
# Standard Magisk install trampoline: sources customize.sh

SKIPUNZIP=1
. /data/adb/magisk/util_functions.sh 2>/dev/null || \
. /data/magisk/util_functions.sh 2>/dev/null || {
  # Fallback minimal stubs for non-Magisk recovery flashing
  ui_print() { echo "$@"; }
  set_perm_recursive() { chmod -R "${3:-755}" "$1"; }
  set_perm() { chmod "${3:-755}" "$1"; }
}

umask 022

[ -z "$MODPATH" ] && MODPATH="/data/adb/modules_update/$(basename "$ZIPFILE" .zip)"
mkdir -p "$MODPATH"

ui_print "- Extracting module..."
unzip -o "$ZIPFILE" -d "$MODPATH" >/dev/null 2>&1

chmod 755 "$MODPATH/customize.sh"
. "$MODPATH/customize.sh"
